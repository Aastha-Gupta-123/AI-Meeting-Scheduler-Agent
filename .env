# ==========================================
# AI Meeting Scheduler Agent Configuration
# ==========================================

# LLM Provider selection: mock, groq, gemini, openai, ollama
# Default is 'mock' which requires no API key and runs locally with rule-based parsing.
# For production-ready AI scheduling, configure 'groq' or 'gemini' and supply their respective keys.
LLM_PROVIDER=mock

# Model Names
# Groq: gemma2-9b-it, llama-3.3-70b-versatile, llama3-8b-8192
# Gemini: gemini-2.5-flash, gemini-1.5-flash
# Ollama: gemma:2b, llama3
# OpenAI: gpt-4o-mini
MODEL_NAME=gemma2-9b-it

# API Keys (Set the key for the provider you choose)
GROQ_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=

# Ollama Endpoint (Only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434

# Embedding Model (Runs locally, no API key needed)
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# Storage Paths
DB_PATH=database/meetings.db
FAISS_PATH=vectorstore/meeting_memory

# Application Settings
LOG_LEVEL=INFO
PORT=7860
HOST=127.0.0.1
